# NotifyPro - Configurações
PORT=3001
NODE_ENV=production

# JWT Secret (troque por uma string aleatória segura)
JWT_SECRET=mude_essa_chave_para_algo_seguro_aqui_123

# Banco de dados SQLite (caminho do arquivo)
DB_PATH=./data/notifypro.db

# Admin padrão (criado no primeiro init)
ADMIN_EMAIL=admin@notifypro.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrador

# CORS - domínios permitidos (separe por vírgula)
ALLOWED_ORIGINS=http://localhost:5173,https://seu-frontend.vercel.app
